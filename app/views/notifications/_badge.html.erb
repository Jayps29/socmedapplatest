<div id="notification_badge">

  <% count = current_user.notifications.unread.count %>

  <% if count.positive? %>

    <span
      class="
        absolute -top-1 -right-1 bg-red-500 text-white text-xs min-w-[18px] h-[18px]
        rounded-full flex items-center justify-center
      "
    >
      <%= count %>
    </span>

  <% end %>

</div>

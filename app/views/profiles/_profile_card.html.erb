<div class="bg-white rounded-xl shadow-sm p-6 mb-6 text-center">

  <% if @user.avatar.attached? %>

    <%= image_tag @user.avatar,
    class:
      "w-32 h-32 rounded-full object-cover border-4 border-white shadow mx-auto" %>

  <% else %>

    <div
      class="
        w-32 h-32 rounded-full bg-gray-300 flex items-center justify-center text-5xl
        mx-auto
      "
    >
      👤
    </div>

  <% end %>

  <h1 class="text-3xl font-bold mt-4">
    <%= @user.first_name %>
    <%= @user.last_name %>
  </h1>

  <p class="text-gray-500">
    @<%= @user.username %>
  </p>

  <% if @user.bio.present? %>

    <p class="mt-4 text-gray-700">
      <%= @user.bio %>
    </p>

  <% end %>

  <%= render "follow_button", user: @user %>

  <%= render "friend_button", user: @user %>

  <%= render "stats", user: @user %>

</div>

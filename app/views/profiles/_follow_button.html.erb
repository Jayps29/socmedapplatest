<% if user_signed_in? && current_user != user %>

  <% if current_user.following?(user) %>

    <%= button_to "Unfollow",
    follow_path(current_user.active_follows.find_by(followed: user)),
    method: :delete,
    class: "mt-4 bg-red-500 hover:bg-red-600 text-white px-4 py-2 rounded-lg" %>

  <% else %>

    <%= button_to "Follow",
    follows_path(user_id: user.id),
    method: :post,
    class: "mt-4 bg-blue-500 hover:bg-blue-600 text-white px-4 py-2 rounded-lg" %>

  <% end %>

<% end %>

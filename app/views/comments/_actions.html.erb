<% if user_signed_in? &&
      (current_user == comment.user ||
       current_user == post.user) %>

  <details class="relative">

    <summary class="list-none cursor-pointer text-gray-500 hover:text-gray-700">
      ⋯
    </summary>

    <div
      class="
        absolute right-0 mt-2 w-40 bg-white rounded-lg shadow-lg border overflow-hidden
        z-10
      "
    >

      <% if current_user == comment.user %>

        <%= link_to "✏️ Edit",
        edit_comment_path(comment),
        data: {
          turbo_frame: dom_id(comment),
        },
        class: "block px-4 py-3 hover:bg-gray-100" %>

      <% end %>

      <%= button_to "🗑️ Delete",
      comment_path(comment),
      method: :delete,
      form: {
        data: {
          turbo_confirm: "Delete this comment?",
        },
      },
      class: "w-full text-left px-4 py-3 hover:bg-gray-100 text-red-600" %>

    </div>

  </details>

<% end %>

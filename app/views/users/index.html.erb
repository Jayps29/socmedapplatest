<div class="max-w-4xl mx-auto">

  <h1 class="text-3xl font-bold">
    Search Results
  </h1>

  <% if params.dig(:q, :username_or_first_name_or_last_name_cont).present? %>

    <p class="text-gray-500 mt-2 mb-8">
      Results for
      <span class="font-semibold text-gray-900">
        "<%= params[:q][:username_or_first_name_or_last_name_cont] %>"
      </span>
    </p>

  <% end %>

  <div class="flex items-center justify-between mb-6">

    <h2 class="text-2xl font-bold">
      👤 Users
    </h2>

    <% if @show_all_users %>

      <%= link_to "See all users",
      "#",
      class: "text-blue-600 hover:text-blue-700 font-medium" %>

    <% end %>

  </div>

  <% if @users.any? %>

    <% @users.each do |user| %>

      <div class="bg-white rounded-xl shadow-sm p-4 mb-3">

        <div class="flex items-center justify-between">

          <div class="flex items-center gap-3">

            <% if user.avatar.attached? %>

              <%= image_tag user.avatar, class: "w-12 h-12 rounded-full object-cover" %>

            <% else %>

              <div
                class="
                  w-12 h-12 rounded-full bg-gray-300 flex items-center justify-center
                "
              >
                👤
              </div>

            <% end %>

            <div>

              <%= link_to user.username,
              profile_path(user),
              class: "font-semibold hover:text-blue-600" %>

              <div class="text-sm text-gray-500">
                <%= user.first_name %>
                <%= user.last_name %>
              </div>

            </div>

          </div>

          <%= link_to "View Profile",
          profile_path(user),
          class:
            "
                          bg-gray-100
                          px-4 py-2
                          rounded-lg
                          hover:bg-gray-200
                        " %>

        </div>

      </div>

    <% end %>

  <% else %>

    <div class="bg-white rounded-xl shadow-sm p-8 text-center mb-8">

      <div class="text-5xl mb-3">
        👤
      </div>

      <p class="text-gray-500">
        No matching users found.
      </p>

    </div>

  <% end %>

  <hr class="my-10">

  <div class="flex items-center justify-between mb-6">

    <h2 class="text-2xl font-bold">
      📝 Posts
    </h2>

    <% if @show_all_posts %>

      <%= link_to "See all posts",
      "#",
      class: "text-blue-600 hover:text-blue-700 font-medium" %>

    <% end %>

  </div>

  <% if @posts.any? %>

    <% @posts.each do |post| %>

      <%= render "posts/search_post", post: post %>

    <% end %>

  <% else %>

    <div class="bg-white rounded-xl shadow-sm p-8 text-center">

      <div class="text-5xl mb-3">
        📝
      </div>

      <p class="text-gray-500">
        No matching posts found.
      </p>

    </div>

  <% end %>

</div>
